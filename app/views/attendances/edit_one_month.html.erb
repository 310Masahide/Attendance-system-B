<% provide(:title, @user.name) %>
<%= form_with(model: @user, url: attendances_update_one_month_user_path(date: @first_day), local: true, method: :patch) do |f| %>
  <div>
    <h1>勤怠編集画面</h1>
    <table class="table table-bordered table-condensed table-hover" id="table-attendances">
      <thead>
        <tr>
          <th>日付</th>
          <th>曜日</th>
          <th>出社</th>
          <th>退社</th>
          <th>在社時間</th>
          <th>備考</th>
          <th>残業指示</th>
          <th>指示者</th>
        </tr>
      </thead>
      <tbody>
        <% @attendances.each do |day| %>
          <%= f.fields_for "attendances[]", day do |attendance| %>
            <tr>
              <td><%= l(day.worked_on, format: :short) %></td>
              <td class="<%= day_of_week_class(day.worked_on) %>"><%= day_of_week(day.worked_on) %></td>
              <% if Date.current < day.worked_on %>
                <td><%= attendance.time_field :started_at, readonly: true, class: "form-control no-picker" %></td>
                <td><%= attendance.time_field :finished_at, readonly: true, class: "form-control no-picker" %></td>
              <% else %>
                <td><%= attendance.time_field :started_at, class: "form-control no-picker" %></td>
                <td><%= attendance.time_field :finished_at, class: "form-control no-picker" %></td>
              <% end %>
              <td>
                <% if day.started_at.present? && day.finished_at.present? %>
                  <%= working_times(day.started_at, day.finished_at) %>
                <% end %>
              </td>
              <td><%= attendance.text_field :note, class: "form-control" %></td>
              <td><%= attendance.text_field :overtime_instruction, class: "form-control" %></td>
              <td><%= attendance.text_field :instructor, class: "form-control" %></td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="btn-edit-one-month">
    <%= link_to "キャンセル", user_path(date: @first_day), class: "btn btn-lg btn-gray-black" %>
    <%= f.submit "編集を保存する", class: "btn btn-lg btn-gray-black" %>
  </div>
<% end %>