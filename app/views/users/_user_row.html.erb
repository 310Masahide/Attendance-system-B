<tr id="<%= dom_id(user) %>">
  <td>
    <% if current_user.admin? %>
      <%= link_to user.name, user %>
    <% else %>
      <%= user.name %>
    <% end %>
    ｜<%= link_to "基本情報編集", edit_basic_info_user_path(user) %>
    <% if !user.admin? %>
      ｜<%= link_to "削除", user, data: { turbo_method: :delete, turbo_confirm: "#{user.name}を削除します。よろしいですか？" } %>
    <% end %>
  </td>
</tr>
