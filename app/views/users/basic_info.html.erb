<% provide(:title, "基本情報の更新") %>
<h1>基本情報の更新</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(url: update_basic_info_users_path, local: true, method: :patch, data: { turbo: false }) do |f| %>
      <%= label_tag :work_time, "指定勤務時間" %>
      <%= time_field_tag :work_time, nil, class: "form-control no-picker" %>

      <%= label_tag :basic_time, "基本勤務時間" %>
      <%= time_field_tag :basic_time, nil, class: "form-control no-picker" %>

      <div class="center btn-basic-info-update">
        <%= f.submit "編集", class: "btn btn-primary btn-block" %>
      </div>
    <% end %>
  </div>
</div>
