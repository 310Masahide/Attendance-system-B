<% provide(:title, 'All Users') %>
<h1>ユーザー覧</h1>


<div class="col-md-10 col-md-offset-1">
  <div class="search-users-wrapper">
    <div class="search-users-block">
      <p class="search-users-label">ユーザー名検索</p>
      <%= form_tag users_path, method: :get, class: "form-inline search-users-form" do %>
        <%= text_field_tag :search, params[:search], placeholder: "キーワードを入力", class: "form-control", autocomplete: "off" %>
        <%= submit_tag "検索", name: nil, class: "btn btn-search" %>
      <% end %>
    </div>
  </div>

  <%= will_paginate %>
  <table class="table table-condensed table-hover" id="table-users">
    <thead>
      <tr>
        <th></th>
      </tr>
    </thead>


    <% @users.each do |user| %>
      <%= render 'user_row', user: user %>
    <% end %>
  </table>
  <%= will_paginate %>
</div>