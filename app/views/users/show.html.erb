<% provide(:title, @user.name) %>
<div>
  <table class="table table-bordered table-condensed user-table">
    <tr>
      <td>
        <%= link_to "⇦", user_path(date: @first_day.prev_month), class: "btn btn-default btn-month-nav" %>　<%= l(@first_day, format: :middle) %>　勤怠管理表　<%= link_to "⇨", user_path(date: @first_day.next_month), class: "btn btn-default btn-month-nav" %>
      </td>
      <td>指定勤務時間　<%= format_basic_info(@user.work_time) %></td>
      <td><%= format_basic_info(@user.basic_time) %>　基本時間</td>
      <td>初日：<%= l(@first_day, format: :short) %></td>
    </tr>

    <tr>
      <td>所属：<%= @user.department.present? ? @user.department : "未所属" %></td>
      <td>名前：<%= @user.name %></td>
      <td>出勤日数：<%= @worked_sum %>日</td>
      <td>締め：<%= l(@last_day, format: :short) %></td>
    </tr>
  </table>
</div>	
<div class="btn-users-show">
  <%= link_to "勤怠を編集", attendances_edit_one_month_user_path(date: @first_day), class: "btn btn-gray-black" %>
</div>
<div>
<table class="table table-bordered table-condensed table-hover" id="table-attendances">	
    <thead>
     <tr>
      <th rowspan="2">日付</th>
      <th rowspan="2">曜日</th>
      <th colspan="3">出社</th>
      <th colspan="3">退社</th>
      <th rowspan="2">在社時間</th>
      <th rowspan="2">備考</th>
      <th rowspan="2">残業指示</th>
      <th rowspan="2">指示者</th>
     </tr>
     <tr>
      <th>時</th>
      <th>分</th>
      <th></th>
      <th>時</th>
      <th>分</th>
      <th></th>
     </tr>
    </thead>
    <tbody>
    <% @attendances.each do |day| %>
      <% started = round_down_to_quarter_hour(day.started_at) %>
      <% finished = round_down_to_quarter_hour(day.finished_at) %>
      <tr>
        <td><%= l(day.worked_on, format: :short) %></td>
        <td class="<%= day_of_week_class(day.worked_on) %>"><%= day_of_week(day.worked_on) %></td>
        <td><%= started.strftime("%H") if started.present? %></td>
        <td><%= started.strftime("%M") if started.present? %></td>
        <td>
          <% if attendance_state(day) == "出勤" %>
            <%= button_to "出社", user_attendance_path(@user, day), method: :patch, class: "btn btn-gray-black btn-attendance btn-block" %>
          <% end %>
        </td>
        <td><%= finished.strftime("%H") if finished.present? %></td>
        <td><%= finished.strftime("%M") if finished.present? %></td>
        <td>
          <% if attendance_state(day) == "退勤" %>
            <%= button_to "退社", user_attendance_path(@user, day), method: :patch, class: "btn btn-gray-black btn-attendance btn-block" %>
          <% end %>
        </td>
        <td>
          <% if started.present? && finished.present? %>
            <%= str_times = working_times(started, finished) %>
            <% @total_working_times = @total_working_times.to_f + str_times.to_f %>
          <% end %>
        </td>
        <td><%= day.note %></td>
        <td><%= day.overtime_instruction %></td>
        <td><%= day.instructor %></td>
      </tr>
      <% end %>
    </tbody>
    
    <tfoot>
      <!--rowspan:縦結合、colspan：横結合-->
      <tr>
        <td colspan="2">累計日数</td>
        <td colspan="3">総合勤務時間</td>
        <td colspan="4">累計在社時間</td>
        <td colspan="3" rowspan="2"></td>
      </tr>
      <tr>
        <td colspan="2"><%= @attendances.count %></td>
        <td colspan="3"><%= total_work_time(@user, @worked_sum) %></td>
        <td colspan="4"><%= format_decimal_time(@total_working_times.to_f) %></td>
      </tr>
    </tfoot> 
  </table>	
</div> 